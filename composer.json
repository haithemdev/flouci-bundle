{
    "name": "haithemdev/flouci-bundle",
    "description": "Ready-to-use Symfony Bundle for Flouci Payment Gateway. Optimized for multi-account and client-specific integrations with event-driven architecture.",
    "keywords": ["flouci", "payment", "gateway", "tunisia", "symfony", "bundle"],
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "haithemdev",
            "email": "haithemdev@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "symfony/framework-bundle": "^6.0|^7.0",
        "symfony/http-client": "^6.0|^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "symfony/test-pack": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Flouci\\SymfonyBundle\\": "src/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "6.*|7.*"
        }
    }
}
